#!/usr/bin/env python3
# maps · cassette.help · MIT
"""
polycule — CLI for the Polycule multi-agent tmux workspace.

Commands:
  start         Init layout + start hub + start TUI + start enabled backend agents
  hub           Start just the hub
  tui           Start just the chat TUI
  agent         Launch an agent adapter OR manage backend agent cooldown state
  approve       Toggle auto-approve mode (on/off)
  status        Check hub status

Run 'polycule <command> --help' for command-specific options.
"""
import argparse
import asyncio
import json
import os
import shlex
import subprocess
import sys
from pathlib import Path

PROJECT_DIR = Path(__file__).parent.parent
SRC_DIR = PROJECT_DIR / 'src'
DB_PATH = PROJECT_DIR / 'polycule.db'
sys.path.insert(0, str(SRC_DIR))

from hermes_sessions import hermes_session_exists
from managed_agents import (
    external_agent_available,
    get_default_backend_agent_modes,
    get_managed_agent_lookup,
    get_managed_agent_names,
    hermes_available,
)
from runtime_state import (
    clear_agent_session_entry,
    get_agent_session_entry,
    get_or_allocate_agent_session_title,
    make_agent_session_key,
    update_agent_session_entry,
)
from session_backends import (
    claude_session_exists,
    codex_session_exists,
    gemini_session_exists,
    newest_claude_session_id,
    newest_codex_session_id,
    newest_gemini_session_id,
    newest_opencode_session_id,
    opencode_session_exists,
)

AGENT_MODE_VALUES = ('mention', 'always', 'off')
CODEX_DISCOVERY_PREFIX = "You are Codex, an AI coding agent participating in the Polycule"
CLAUDE_DISCOVERY_HINT = (
    "You are Claude, an AI assistant participating in the Polycule "
    "multi-agent workspace."
)
GEMINI_DISCOVERY_HINT = (
    "You are Gemini, an AI assistant participating in the Polycule "
    "multi-agent workspace."
)


def _managed_backend_agents() -> tuple[str, ...]:
    return tuple(get_managed_agent_names())


def _managed_agent_lookup():
    return get_managed_agent_lookup()


def _default_agent_modes() -> dict[str, str]:
    return get_default_backend_agent_modes()


def _default_agent_mode(agent_name: str) -> str:
    return _default_agent_modes().get(agent_name.strip().lower(), 'mention')


def _launchable_agents() -> tuple[str, ...]:
    managed = set(_managed_backend_agents())
    managed.update({'hermes', 'claude', 'codex', 'opencode', 'gemini'})
    return tuple(sorted(managed))


def _default_human_name() -> str:
    return (
        os.environ.get('POLYCULE_OPERATOR_NAME')
        or os.environ.get('USER')
        or os.environ.get('LOGNAME')
        or 'you'
    )


def _db():
    from backend.db import PolyculeDB

    return PolyculeDB(db_path=DB_PATH)


def _load_disabled_agents() -> set[str]:
    raw = _db().get_setting('disabled_agents', '[]') or '[]'
    try:
        items = json.loads(raw)
        if not isinstance(items, list):
            items = []
    except json.JSONDecodeError:
        items = []
    managed = set(_managed_backend_agents())
    return {str(item).lower() for item in items if str(item).lower() in managed}


def _save_disabled_agents(disabled: set[str]):
    managed = set(_managed_backend_agents())
    payload = sorted(a for a in disabled if a in managed)
    _db().set_setting('disabled_agents', json.dumps(payload))


def _load_agent_modes() -> dict[str, str]:
    modes = dict(_default_agent_modes())
    raw = _db().get_setting('agent_modes', '') or ''
    if not raw:
        return modes
    try:
        parsed = json.loads(raw)
    except json.JSONDecodeError:
        return modes
    if not isinstance(parsed, dict):
        return modes
    for agent in _managed_backend_agents():
        value = str(parsed.get(agent, '')).strip().lower()
        if value in AGENT_MODE_VALUES:
            modes[agent] = value
    return modes


def _save_agent_modes(modes: dict[str, str]):
    payload = {}
    defaults = _default_agent_modes()
    for agent in _managed_backend_agents():
        fallback = defaults.get(agent, 'mention')
        value = str(modes.get(agent, fallback)).strip().lower()
        payload[agent] = value if value in AGENT_MODE_VALUES else fallback
    _db().set_setting('agent_modes', json.dumps(payload))


def _tmux_send(pane_id: str, *keys: str):
    subprocess.run(['tmux', 'send-keys', '-t', pane_id, *keys], check=False)


def _reset_pane(pane_id: str):
    _tmux_send(pane_id, 'C-c')
    _tmux_send(pane_id, 'C-c')
    _tmux_send(pane_id, 'clear', 'Enter')


def _run_in_pane(pane_id: str, command: str):
    _reset_pane(pane_id)
    _tmux_send(pane_id, command, 'Enter')


def _backend_agent_command(agent_name: str, room: str, mode: str = 'mention') -> str:
    room_q = shlex.quote(room)
    proj_q = shlex.quote(str(PROJECT_DIR))
    agent = agent_name.lower()
    mode = mode.lower().strip()
    spec = _managed_agent_lookup().get(agent)
    if spec and spec.adapter == 'hermes':
        always_flag = ' --always' if mode == 'always' else ''
        resume_flag = _managed_hermes_resume_flag(spec.profile, room)
        title_flag = (
            f" --session-title "
            f"{shlex.quote(_ensure_managed_session_title('hermes', room, profile=spec.profile))}"
        )
        return (
            f"cd {proj_q} && "
            f"nocorrect python3 {shlex.quote(str(SRC_DIR / 'agents' / 'hermes_adapter.py'))} "
            f"--name {shlex.quote(spec.name)} --profile {shlex.quote(spec.profile)} "
            f"--room {room_q}{title_flag}{resume_flag}{always_flag}"
        )
    if agent == 'codex':
        always_flag = ' --always' if mode == 'always' else ''
        resume_flag = _managed_resume_flag('codex', room)
        title_flag = f" --session-title {shlex.quote(_ensure_managed_session_title('codex', room))}"
        return (
            f"cd {proj_q} && "
            f"nocorrect python3 {shlex.quote(str(SRC_DIR / 'agents' / 'codex_adapter.py'))} "
            f"--name codex --room {room_q}{title_flag}{resume_flag}{always_flag}"
        )
    if agent == 'claude':
        always_flag = ' --always' if mode == 'always' else ''
        resume_flag = _managed_resume_flag('claude', room)
        title_flag = f" --session-title {shlex.quote(_ensure_managed_session_title('claude', room))}"
        return (
            f"cd {proj_q} && "
            f"nocorrect python3 {shlex.quote(str(SRC_DIR / 'agents' / 'claude_adapter.py'))} "
            f"--name claude --room {room_q}{title_flag}{resume_flag}{always_flag}"
        )
    if agent == 'opencode':
        always_flag = ' --always' if mode == 'always' else ''
        resume_flag = _managed_resume_flag('opencode', room)
        title_flag = f" --session-title {shlex.quote(_ensure_managed_session_title('opencode', room))}"
        return (
            f"cd {proj_q} && "
            f"nocorrect python3 {shlex.quote(str(SRC_DIR / 'agents' / 'opencode_adapter.py'))} "
            f"--name opencode --room {room_q}{title_flag}{resume_flag}{always_flag}"
        )
    if agent == 'gemini':
        always_flag = ' --always' if mode == 'always' else ''
        resume_flag = _managed_resume_flag('gemini', room)
        title_flag = f" --session-title {shlex.quote(_ensure_managed_session_title('gemini', room))}"
        return (
            f"cd {proj_q} && "
            f"nocorrect python3 {shlex.quote(str(SRC_DIR / 'agents' / 'gemini_adapter.py'))} "
            f"--name gemini --room {room_q}{title_flag}{resume_flag}{always_flag}"
        )
    raise ValueError(f'Unsupported backend agent: {agent_name}')


def _disabled_notice_command(agent_name: str) -> str:
    msg = f"[cooldown] {agent_name} disabled. re-enable with: polycule agent enable {agent_name}"
    return f"echo {shlex.quote(msg)}"


def _mode_off_notice_command(agent_name: str) -> str:
    msg = f"[mode=off] {agent_name} muted. set mode with: polycule agent mode {agent_name} mention|always"
    return f"echo {shlex.quote(msg)}"


def _unavailable_notice_command(agent_name: str, detail: str) -> str:
    msg = (
        f"[unavailable] {agent_name} skipped. {detail}. "
        f"disable with: polycule agent disable {agent_name}"
    )
    return f"echo {shlex.quote(msg)}"


def _agent_availability(agent_name: str) -> tuple[bool, str]:
    agent = agent_name.strip().lower()
    spec = _managed_agent_lookup().get(agent)
    adapter = spec.adapter if spec else agent

    if adapter == 'hermes':
        return hermes_available()
    if adapter in {'codex', 'claude', 'opencode', 'gemini'}:
        return external_agent_available(adapter)
    return False, f"unknown dependency for {agent_name}"


def _find_named_panes(label: str) -> list[str]:
    result = subprocess.run(
        ['tmux', 'list-panes', '-a', '-F', '#{pane_id}:#{@name}'],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return []

    pane_ids = []
    for line in result.stdout.strip().splitlines():
        parts = line.split(':', 1)
        if len(parts) != 2:
            continue
        pane_id, pane_label = parts[0], parts[1].strip().lower()
        if pane_label == label.lower():
            pane_ids.append(pane_id)
    return pane_ids


def _resolve_managed_hermes_session(profile: str, room: str) -> str | None:
    key = make_agent_session_key('hermes', room, profile=profile)
    entry = get_agent_session_entry(key)
    if not entry:
        return None
    session_id = str(entry.get('session_id', '')).strip()
    if not session_id:
        return None
    if not hermes_session_exists(profile, session_id):
        clear_agent_session_entry(key)
        return None
    return session_id


def _managed_session_key(agent_family: str, room: str, *, profile: str = '') -> str:
    return make_agent_session_key(agent_family, room, profile=profile)


def _ensure_managed_session_title(agent_family: str, room: str, *, profile: str = '') -> str:
    key = _managed_session_key(agent_family, room, profile=profile)
    title = get_or_allocate_agent_session_title(key)
    entry = get_agent_session_entry(key) or {}
    if str(entry.get('title', '')).strip() == title:
        return title
    normalized_profile = profile if profile else agent_family
    agent_name = profile if profile else agent_family
    update_agent_session_entry(
        key,
        agent_family=agent_family,
        profile=normalized_profile,
        room=room,
        agent_name=agent_name,
        title=title,
    )
    return title


def _managed_session_title(agent_name: str, room: str, *, profile: str = '') -> str:
    agent = agent_name.strip().lower()
    return _ensure_managed_session_title(agent, room, profile=profile)


def _persist_managed_session(
    agent_family: str,
    room: str,
    session_id: str,
    *,
    profile: str = '',
):
    normalized_profile = profile if profile else agent_family
    key = make_agent_session_key(agent_family, room, profile=profile)
    title = _managed_session_title(agent_family, room, profile=profile)
    agent_name = profile if profile else agent_family
    update_agent_session_entry(
        key,
        agent_family=agent_family,
        profile=normalized_profile,
        room=room,
        agent_name=agent_name,
        title=title,
        session_id=session_id,
    )


def _resolve_saved_session(
    agent_family: str,
    room: str,
    *,
    profile: str = '',
    exists_fn,
) -> str | None:
    key = make_agent_session_key(agent_family, room, profile=profile)
    entry = get_agent_session_entry(key)
    if not entry:
        return None
    session_id = str(entry.get('session_id', '')).strip()
    if not session_id:
        return None
    if not exists_fn(session_id):
        clear_agent_session_entry(key)
        return None
    return session_id


def _resolve_managed_codex_session(room: str) -> str | None:
    session_id = _resolve_saved_session(
        'codex',
        room,
        exists_fn=codex_session_exists,
    )
    if session_id:
        return session_id
    session_id = newest_codex_session_id(
        PROJECT_DIR,
        title_prefix=CODEX_DISCOVERY_PREFIX,
    )
    if session_id:
        _persist_managed_session('codex', room, session_id)
    return session_id


def _resolve_managed_claude_session(room: str) -> str | None:
    session_id = _resolve_saved_session(
        'claude',
        room,
        exists_fn=lambda sid: claude_session_exists(PROJECT_DIR, sid),
    )
    if session_id:
        return session_id
    session_id = newest_claude_session_id(
        PROJECT_DIR,
        content_hint=CLAUDE_DISCOVERY_HINT,
    )
    if session_id:
        _persist_managed_session('claude', room, session_id)
    return session_id


def _resolve_managed_opencode_session(room: str) -> str | None:
    session_title = _managed_session_title('opencode', room)
    session_id = _resolve_saved_session(
        'opencode',
        room,
        exists_fn=opencode_session_exists,
    )
    if session_id:
        return session_id
    session_id = newest_opencode_session_id(
        PROJECT_DIR,
        title=session_title,
    )
    if session_id:
        _persist_managed_session('opencode', room, session_id)
    return session_id


def _resolve_managed_gemini_session(room: str) -> str | None:
    session_id = _resolve_saved_session(
        'gemini',
        room,
        exists_fn=lambda sid: gemini_session_exists(PROJECT_DIR, sid),
    )
    if session_id:
        return session_id
    session_id = newest_gemini_session_id(
        PROJECT_DIR,
        content_hint=GEMINI_DISCOVERY_HINT,
    )
    if session_id:
        _persist_managed_session('gemini', room, session_id)
    return session_id


def _resolve_managed_session(agent_name: str, room: str) -> str | None:
    agent = agent_name.strip().lower()
    spec = _managed_agent_lookup().get(agent)
    if spec and spec.adapter == 'hermes':
        return _resolve_managed_hermes_session(spec.profile, room)
    if agent == 'codex':
        return _resolve_managed_codex_session(room)
    if agent == 'claude':
        return _resolve_managed_claude_session(room)
    if agent == 'opencode':
        return _resolve_managed_opencode_session(room)
    if agent == 'gemini':
        return _resolve_managed_gemini_session(room)
    return None


def _managed_hermes_resume_flag(profile: str, room: str) -> str:
    session_id = _resolve_managed_hermes_session(profile, room)
    if not session_id:
        return ''
    return f" --resume {shlex.quote(session_id)}"


def _managed_resume_flag(agent_name: str, room: str) -> str:
    session_id = _resolve_managed_session(agent_name, room)
    if not session_id:
        return ''
    return f" --resume {shlex.quote(session_id)}"


def _set_agent_runtime_state(agent_name: str, enabled: bool, room: str, modes: dict[str, str] | None = None):
    panes = _find_named_panes(agent_name)
    if not panes:
        return
    modes = modes or _load_agent_modes()
    mode = str(modes.get(agent_name, _default_agent_mode(agent_name))).lower()
    available, detail = _agent_availability(agent_name)
    for pane_id in panes:
        if not enabled:
            _run_in_pane(pane_id, _disabled_notice_command(agent_name))
            continue
        if mode == 'off':
            _run_in_pane(pane_id, _mode_off_notice_command(agent_name))
        elif not available:
            _run_in_pane(pane_id, _unavailable_notice_command(agent_name, detail))
        else:
            _run_in_pane(pane_id, _backend_agent_command(agent_name, room, mode=mode))


def _set_agent_enabled(agent_name: str, enabled: bool, room: str):
    disabled = _load_disabled_agents()
    modes = _load_agent_modes()
    if enabled:
        disabled.discard(agent_name)
    else:
        disabled.add(agent_name)
    _save_disabled_agents(disabled)
    _set_agent_runtime_state(agent_name, enabled=enabled, room=room, modes=modes)


def _set_agent_mode(agent_name: str, mode: str, room: str):
    normalized = mode.strip().lower()
    if normalized not in AGENT_MODE_VALUES:
        raise ValueError(f'Invalid mode: {mode}')
    modes = _load_agent_modes()
    modes[agent_name] = normalized
    _save_agent_modes(modes)
    disabled = _load_disabled_agents()
    _set_agent_runtime_state(agent_name, enabled=(agent_name not in disabled), room=room, modes=modes)


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

def cmd_start(args):
    """Full launch: init session, start hub, start TUI, start enabled backend agents."""
    from session_init import init

    print("Starting Polycule...")
    managed_agents = list(_managed_backend_agents())
    session, panes = init(force_new=args.new, backend_labels=managed_agents)

    hub_pane = panes.get('hub_log')
    chat_pane = panes.get('chat')
    disabled = _load_disabled_agents()
    modes = _load_agent_modes()

    if hub_pane:
        hub_cmd = f'cd {shlex.quote(str(PROJECT_DIR))} && python3 {shlex.quote(str(SRC_DIR / "backend" / "hub.py"))}'
        _run_in_pane(hub_pane, hub_cmd)
        print(f"  Hub starting in pane {hub_pane}")
    else:
        print("  Warning: no hub_log pane found; start hub manually: polycule hub")

    if chat_pane:
        print(f"  Waiting for hub readiness on localhost:7777 (timeout: {args.hub_timeout:.1f}s)")
        ready = asyncio.run(_wait_for_hub(timeout=args.hub_timeout))
        if not ready:
            print(
                f"  Error: hub not reachable on localhost:7777 after {args.hub_timeout:.1f}s",
                file=sys.stderr,
            )
            print("  TUI not started.", file=sys.stderr)
            sys.exit(1)
        tui_cmd = (
            f'cd {shlex.quote(str(PROJECT_DIR))} && '
            f'python3 {shlex.quote(str(SRC_DIR / "ui" / "chat_tui.py"))} '
            f'--name {shlex.quote(args.name)} --room {shlex.quote(args.room)}'
        )
        _run_in_pane(chat_pane, tui_cmd)
        print(f"  TUI starting in pane {chat_pane}")
    else:
        print("  Warning: no chat pane found; start TUI manually: polycule tui")

    print("  Backend agents:")
    if not managed_agents:
        print("    - none discovered on this machine")
    for agent in managed_agents:
        pane_id = panes.get(agent)
        if not pane_id:
            print(f"    - {agent}: missing pane")
            continue
        mode = modes.get(agent, _default_agent_mode(agent))
        if agent in disabled:
            _run_in_pane(pane_id, _disabled_notice_command(agent))
            print(f"    - {agent}: disabled (cooldown)")
            continue
        if mode == 'off':
            _run_in_pane(pane_id, _mode_off_notice_command(agent))
            print(f"    - {agent}: mode off (muted)")
            continue
        available, detail = _agent_availability(agent)
        if not available:
            _run_in_pane(pane_id, _unavailable_notice_command(agent, detail))
            print(f"    - {agent}: unavailable, skipped ({detail})")
            continue
        _run_in_pane(pane_id, _backend_agent_command(agent, args.room, mode=mode))
        print(f"    - {agent}: started in {pane_id} (mode={mode})")

    if getattr(args, 'background', False):
        print(f"\nPolycule running in background — attach with: tmux attach -t {session}:polycule")
        return
    print(f"\nAttaching to session: {session}")
    os.execvp('tmux', ['tmux', 'attach-session', '-t', f'{session}:polycule'])


def cmd_hub(args):
    """Start just the hub."""
    hub_py = SRC_DIR / 'backend' / 'hub.py'
    os.execv(sys.executable, [sys.executable, str(hub_py)])


def cmd_tui(args):
    """Start just the chat TUI."""
    tui_py = SRC_DIR / 'ui' / 'chat_tui.py'
    extra = []
    if args.name:
        extra += ['--name', args.name]
    if args.room:
        extra += ['--room', args.room]
    if args.host:
        extra += ['--host', args.host]
    if args.port:
        extra += ['--port', str(args.port)]
    os.execv(sys.executable, [sys.executable, str(tui_py)] + extra)


def cmd_agent(args):
    """Launch adapter OR manage backend agent cooldown state."""
    action = args.agent_or_action.lower()
    managed_agents = _managed_backend_agents()
    managed_lookup = _managed_agent_lookup()

    if action in ('enable', 'disable', 'status', 'mode', 'modes'):
        if action == 'status':
            disabled = _load_disabled_agents()
            modes = _load_agent_modes()
            enabled = [a for a in managed_agents if a not in disabled]
            print(f"Enabled:  {', '.join(enabled) if enabled else '(none)'}")
            print(f"Disabled: {', '.join(sorted(disabled)) if disabled else '(none)'}")
            for agent in managed_agents:
                state = 'disabled' if agent in disabled else 'enabled'
                mode = modes.get(agent, _default_agent_mode(agent))
                available, detail = _agent_availability(agent)
                availability = 'available' if available else 'missing'
                line = f"{agent}: state={state} mode={mode} availability={availability}"
                spec = managed_lookup.get(agent)
                if spec and spec.adapter == 'hermes':
                    line += f" adapter=hermes profile={spec.profile}"
                elif spec:
                    line += f" adapter={spec.adapter}"
                if detail:
                    line += f" detail={detail}"
                print(line)
            return

        if action == 'modes':
            modes = _load_agent_modes()
            for agent in managed_agents:
                print(f"{agent}: {modes.get(agent, _default_agent_mode(agent))}")
            return

        target = (args.target_agent or '').strip().lower()
        if target not in managed_lookup:
            print(f"Unknown backend agent: {target or '(missing)'}", file=sys.stderr)
            print(f"Available: {', '.join(managed_agents) if managed_agents else '(none)'}", file=sys.stderr)
            sys.exit(1)

        if action == 'mode':
            mode_value = (args.action_value or '').strip().lower()
            if mode_value not in AGENT_MODE_VALUES:
                print(
                    f"Invalid mode: {mode_value or '(missing)'} "
                    f"(expected one of: {', '.join(AGENT_MODE_VALUES)})",
                    file=sys.stderr,
                )
                sys.exit(1)
            _set_agent_mode(target, mode_value, room=args.room)
            print(f"Set mode {target}={mode_value}")
            return

        enabling = action == 'enable'
        _set_agent_enabled(target, enabled=enabling, room=args.room)
        print(f"{'Enabled' if enabling else 'Disabled'} {target}")
        return

    agent_scripts = {
        'hermes': SRC_DIR / 'agents' / 'hermes_adapter.py',
        'claude': SRC_DIR / 'agents' / 'claude_adapter.py',
        'codex': SRC_DIR / 'agents' / 'codex_adapter.py',
        'opencode': SRC_DIR / 'agents' / 'opencode_adapter.py',
        'gemini': SRC_DIR / 'agents' / 'gemini_adapter.py',
    }

    agent_type = action
    if agent_type not in _launchable_agents():
        print(f"Unknown agent type/action: {action}")
        print(f"Launchable agents: {', '.join(_launchable_agents())}")
        print("Cooldown controls: enable <agent>, disable <agent>, status")
        sys.exit(1)

    script_key = 'hermes' if agent_type == 'hermes' else agent_type
    extra_flags = []
    selected_profile = None
    default_name = None

    managed_spec = managed_lookup.get(agent_type)
    if agent_type == 'hermes':
        selected_profile = (args.profile or 'default').strip().lower() or 'default'
        default_name = 'hermes' if selected_profile in {'', 'default', 'hermes'} else selected_profile
        extra_flags += ['--profile', selected_profile]
    elif managed_spec and managed_spec.adapter == 'hermes':
        script_key = 'hermes'
        selected_profile = managed_spec.profile
        default_name = managed_spec.name
        extra_flags += ['--profile', selected_profile]
    elif managed_spec:
        script_key = managed_spec.adapter
        default_name = managed_spec.name

    if default_name and not args.name:
        extra_flags += ['--name', default_name]

    agent_py = agent_scripts.get(script_key)
    if not agent_py:
        print(f"Unknown agent type: {agent_type}")
        print(f"Available: {', '.join(_launchable_agents())}")
        sys.exit(1)

    if script_key == 'hermes':
        available, detail = hermes_available()
    else:
        available, detail = _agent_availability(script_key)
    if not available:
        print(f"Cannot launch {agent_type}: {detail}", file=sys.stderr)
        sys.exit(1)

    extra = []
    if args.name:
        extra += ['--name', args.name]
    if args.room:
        extra += ['--room', args.room]
    if args.host:
        extra += ['--host', args.host]
    if args.port:
        extra += ['--port', str(args.port)]
    if getattr(args, 'always', False):
        extra += ['--always']
    if getattr(args, 'always_all', False):
        extra += ['--always-all']
    if script_key != 'hermes':
        extra += ['--session-title', _ensure_managed_session_title(script_key, args.room)]
    elif selected_profile:
        extra += ['--session-title', _ensure_managed_session_title('hermes', args.room, profile=selected_profile)]
    resolved_resume = getattr(args, 'resume', None)
    if not resolved_resume:
        if script_key == 'hermes' and selected_profile:
            resolved_resume = _resolve_managed_hermes_session(selected_profile, args.room)
        elif script_key in ('codex', 'claude', 'opencode', 'gemini'):
            resolved_resume = _resolve_managed_session(script_key, args.room)
    if resolved_resume:
        extra += ['--resume', resolved_resume]

    os.execv(sys.executable, [sys.executable, str(agent_py)] + extra_flags + extra)


def cmd_approve(args):
    """Toggle auto-approve mode by sending command to hub."""
    value = args.setting.lower() not in ('off', '0', 'false', 'no')
    asyncio.run(_send_hub_command({'type': 'command', 'command': 'set_auto_approve', 'value': value}))
    status = 'enabled' if value else 'disabled'
    print(f"Auto-approve {status}")


def cmd_status(args):
    """Check if hub is reachable."""
    asyncio.run(_check_status())


async def _send_hub_command(msg: dict, host: str = 'localhost', port: int = 7777):
    try:
        r, w = await asyncio.open_connection(host, port)
        handshake = {'type': 'handshake', 'name': 'polycule-cli', 'agent_type': 'human', 'room_name': 'Default'}
        w.write((json.dumps(handshake) + '\n').encode())
        await w.drain()

        def _is_awaiting_room(payload: dict) -> bool:
            return payload.get('action') == 'awaiting_room'

        data = await asyncio.wait_for(r.readline(), timeout=3.0)
        response = json.loads(data.decode().strip() or '{}')
        if _is_awaiting_room(response):
            join = {'type': 'command', 'command': 'create_room', 'room_name': 'Default'}
            w.write((json.dumps(join) + '\n').encode())
            await w.drain()
            await asyncio.wait_for(r.readline(), timeout=3.0)
        else:
            try:
                data = await asyncio.wait_for(r.readline(), timeout=0.2)
                if data:
                    response = json.loads(data.decode().strip() or '{}')
                    if _is_awaiting_room(response):
                        join = {'type': 'command', 'command': 'create_room', 'room_name': 'Default'}
                        w.write((json.dumps(join) + '\n').encode())
                        await w.drain()
                        await asyncio.wait_for(r.readline(), timeout=3.0)
            except asyncio.TimeoutError:
                pass

        w.write((json.dumps(msg) + '\n').encode())
        await w.drain()
        w.close()
        await w.wait_closed()
    except Exception as e:
        print(f"Hub command failed: {e}", file=sys.stderr)


async def _check_status(host: str = 'localhost', port: int = 7777):
    try:
        _r, w = await asyncio.open_connection(host, port)
        w.close()
        await w.wait_closed()
        print(f"Hub: UP ({host}:{port})")
    except ConnectionRefusedError:
        print(f"Hub: DOWN (nothing listening on {host}:{port})")
    except Exception as e:
        print(f"Hub: ERROR - {e}")


async def _wait_for_hub(
    host: str = 'localhost',
    port: int = 7777,
    timeout: float = 10.0,
    interval: float = 0.2,
) -> bool:
    deadline = asyncio.get_running_loop().time() + timeout
    while asyncio.get_running_loop().time() < deadline:
        try:
            _r, w = await asyncio.open_connection(host, port)
            w.close()
            await w.wait_closed()
            return True
        except Exception:
            await asyncio.sleep(interval)
    return False


# ---------------------------------------------------------------------------
# Argument parser
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog='polycule',
        description='Polycule multi-agent workspace CLI',
    )
    sub = p.add_subparsers(dest='command', metavar='COMMAND')

    # start
    s = sub.add_parser('start', help='Full launch: session + hub + TUI + backend agents')
    s.add_argument('--name', default=_default_human_name())
    s.add_argument('--room', default='Default')
    s.add_argument('--new', action='store_true', help='Force new tmux session')
    s.add_argument('--hub-timeout', type=float, default=10.0, help='Seconds to wait for hub readiness')
    s.add_argument('--background', action='store_true', help='Start services without attaching to tmux (for launchd/cron)')

    # hub
    sub.add_parser('hub', help='Start just the hub')

    # tui
    t = sub.add_parser('tui', help='Start just the chat TUI')
    t.add_argument('--name', default=_default_human_name())
    t.add_argument('--room', default='Default')
    t.add_argument('--host', default='localhost')
    t.add_argument('--port', type=int, default=7777)

    # agent
    a = sub.add_parser('agent', help='Launch adapter or manage cooldown state')
    a.add_argument(
        'agent_or_action',
        metavar='TYPE|ACTION',
        help='TYPE: hermes|<discovered-agent>|claude|codex|opencode|gemini; ACTION: enable|disable|status|mode|modes',
    )
    a.add_argument(
        'target_agent',
        nargs='?',
        metavar='AGENT',
        help='required for enable/disable/mode: one of the discovered managed agents',
    )
    a.add_argument(
        'action_value',
        nargs='?',
        metavar='VALUE',
        help='for mode action: mention|always|off',
    )
    a.add_argument('--name', default=None)
    a.add_argument('--room', default='Default')
    a.add_argument('--host', default='localhost')
    a.add_argument('--port', type=int, default=7777)
    a.add_argument('--profile', default='default', help='Hermes profile name when TYPE is hermes')
    a.add_argument('--always', action='store_true', help='Respond to all messages')
    a.add_argument('--always-all', action='store_true', help='Respond to all messages including agent output (unsafe)')
    a.add_argument('--resume', default=None, metavar='SESSION_ID', help='Resume a prior session by ID')

    # approve
    ap = sub.add_parser('approve', help='Toggle auto-approve mode')
    ap.add_argument('setting', choices=['on', 'off'], help='on | off')

    # status
    sub.add_parser('status', help='Check hub status')

    return p


COMMAND_HANDLERS = {
    'start': cmd_start,
    'hub': cmd_hub,
    'tui': cmd_tui,
    'agent': cmd_agent,
    'approve': cmd_approve,
    'status': cmd_status,
}


def main():
    parser = build_parser()
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(0)

    handler = COMMAND_HANDLERS.get(args.command)
    if not handler:
        parser.print_help()
        sys.exit(1)

    handler(args)


if __name__ == '__main__':
    main()
