#!/usr/bin/env python3
# maps · cassette.help · MIT
"""
polycule init — setup wizard

Detects installed AI tools, asks a few questions, and writes polycule.toml.
"""
import shutil
import sys
from pathlib import Path

CONFIG_PATH = Path("polycule.toml")


def yn(prompt: str, default: bool = True) -> bool:
    marker = "[Y/n]" if default else "[y/N]"
    while True:
        raw = input(f"{prompt} {marker} ").strip().lower()
        if not raw:
            return default
        if raw in ("y", "yes"):
            return True
        if raw in ("n", "no"):
            return False


def ask(prompt: str, default: str = "") -> str:
    suffix = f" [{default}]" if default else ""
    raw = input(f"{prompt}{suffix}: ").strip()
    return raw if raw else default


def detect_tools() -> dict[str, str | None]:
    tools = {
        "claude": shutil.which("claude"),
        "codex":  shutil.which("codex"),
        "ollama": shutil.which("ollama"),
        "llm":    shutil.which("llm"),
    }
    return {k: v for k, v in tools.items() if v}


def main():
    print("\n  polycule init — multi-agent hub setup\n")

    if CONFIG_PATH.exists():
        if not yn(f"{CONFIG_PATH} already exists. Overwrite?", default=False):
            print("Aborted.")
            sys.exit(0)

    name = ask("Your name in the chat", default="you")
    room = ask("Default room name", default="Main")
    port = ask("Hub port", default="7777")

    found = detect_tools()
    if found:
        print(f"\n  Detected: {', '.join(found.keys())}")
    else:
        print("\n  No known AI tools found in PATH.")
        print("  You can add shell agents manually in polycule.toml.\n")

    agents = []

    if "claude" in found:
        if yn("  Add Claude adapter?"):
            trigger = ask("  Claude trigger words (comma-separated)", default="@claude,claude")
            always = yn("  Respond to all messages (not just mentions)?", default=False)
            agents.append({
                "name": "Claude",
                "adapter": "claude",
                "room": room,
                "triggers": [t.strip() for t in trigger.split(",")],
                "always": always,
                "enabled": True,
            })

    if "codex" in found:
        if yn("  Add Codex adapter?"):
            trigger = ask("  Codex trigger words (comma-separated)", default="@codex,codex")
            always = yn("  Respond to all messages?", default=False)
            agents.append({
                "name": "Codex",
                "adapter": "codex",
                "room": room,
                "triggers": [t.strip() for t in trigger.split(",")],
                "always": always,
                "enabled": True,
            })

    if "ollama" in found:
        if yn("  Add an Ollama agent?"):
            model = ask("  Ollama model", default="mistral")
            agent_name = ask("  Agent name", default=model.capitalize())
            trigger_default = f"@{agent_name.lower()},{agent_name.lower()}"
            trigger = ask("  Trigger words", default=trigger_default)
            always = yn("  Respond to all messages?", default=False)
            agents.append({
                "name": agent_name,
                "adapter": "shell",
                "command": f"ollama run {model}",
                "room": room,
                "triggers": [t.strip() for t in trigger.split(",")],
                "always": always,
                "enabled": True,
            })

    if "llm" in found:
        if yn("  Add an llm agent (Simon Willison's llm tool)?"):
            model = ask("  Model ID", default="gpt-4o-mini")
            agent_name = ask("  Agent name", default="GPT")
            trigger_default = f"@{agent_name.lower()},{agent_name.lower()}"
            trigger = ask("  Trigger words", default=trigger_default)
            always = yn("  Respond to all messages?", default=False)
            agents.append({
                "name": agent_name,
                "adapter": "shell",
                "command": f"llm -m {model}",
                "room": room,
                "triggers": [t.strip() for t in trigger.split(",")],
                "always": always,
                "enabled": True,
            })

    while yn("\n  Add a custom shell agent?", default=False):
        agent_name = ask("  Agent name")
        command = ask("  Command (reads stdin, writes stdout)")
        trigger_default = f"@{agent_name.lower()},{agent_name.lower()}"
        trigger = ask("  Trigger words", default=trigger_default)
        always = yn("  Respond to all messages?", default=False)
        agents.append({
            "name": agent_name,
            "adapter": "shell",
            "command": command,
            "room": room,
            "triggers": [t.strip() for t in trigger.split(",")],
            "always": always,
            "enabled": True,
        })

    # Write config
    lines = [
        "# polycule.toml — generated by polycule init\n",
        "[hub]",
        'host = "localhost"',
        f"port = {port}\n",
        "[tui]",
        f'default_room = "{room}"',
        f'default_name = "{name}"\n',
    ]

    for a in agents:
        lines.append("[[agent]]")
        lines.append(f'name    = "{a["name"]}"')
        lines.append(f'adapter = "{a["adapter"]}"')
        if "command" in a:
            lines.append(f'command = "{a["command"]}"')
        lines.append(f'room    = "{a["room"]}"')
        trigger_str = ", ".join(f'"{t}"' for t in a["triggers"])
        lines.append(f"triggers = [{trigger_str}]")
        lines.append(f'always  = {"true" if a["always"] else "false"}')
        lines.append(f'enabled = true')
        lines.append("")

    CONFIG_PATH.write_text("\n".join(lines))
    print(f"\n  Written: {CONFIG_PATH.resolve()}")
    print("\n  Start with:")
    print("    polycule hub       # in one terminal")
    print(f"    polycule tui --name {name} --room {room}")
    print("    polycule agents    # start all configured agents in background\n")


if __name__ == "__main__":
    main()
